# Rust / Soroban
/target/
**/target/
*.wasm
.soroban/
.stellar/

# Node (frontend / settler / bot — added in later milestones)
node_modules/
dist/
.pnp.*
.yarn/
*.tsbuildinfo

# Local runtime state (regenerated by scripts/deploy_and_smoke.sh)
/.stelvin/

# Secrets / local config
.env
.env.*
!.env.example
*.key
identity*.toml
secret*.txt

# Cloned reference repos (not part of Stelvin's own source)
/stellar-ai-guide/
/stellar-build/

# Hero source clip — the canvas hero serves the extracted frames in
# web/public/frames (committed, needed by the Vercel build); the raw mp4 itself
# is a build input only, so keep it out of git. Re-extract with:
#   ffmpeg -i input.mp4 -vf "fps=15,scale=1280:-1" -q:v 8 web/public/frames/frame_%04d.jpg
/input.mp4

# OS / editor
.DS_Store
Thumbs.db
*.log

# Keep editor workspace settings out by default (uncomment to share)
.idea/

/noether-web/
# Soroban test execution snapshots (regenerated by cargo test)
**/test_snapshots/

# Vercel link dir
.vercel
